<!-- Features Section -->
<section id="features" class="features-section">
    <div class="container">
        <div class="section-header text-center">
            <span class="section-badge">Core Features</span>
            <h2>Everything you need.<br /><span class="gradient-text">Nothing you don't.</span></h2>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon bg-blue"><i class="fas fa-th"></i></div>
                    <h3>Interactive Schedule Grid</h3>
                    <p>
                        A powerful time-matrix view &mdash; employees on rows, days on columns.
                        Drag and drop shifts, right-click for context actions, and see changes
                        propagate <strong>in real-time</strong> across all connected users via SignalR.
                    </p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card highlight-card">
                    <div class="feature-icon bg-purple"><i class="fas fa-magic"></i></div>
                    <h3>Auto-Fill Scheduling</h3>
                    <p>
                        One click. That's all it takes. Klacks analyzes availability, qualifications,
                        work-hour limits, and preferences &mdash; then <strong>fills your entire schedule
                        automatically</strong>. An evolutionary algorithm tests 50+ scenarios to find
                        the optimal assignment.
                    </p>
                    <span class="feature-tag">Most Popular</span>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon bg-green"><i class="fas fa-cut"></i></div>
                    <h3>Shift Cutting &amp; Splitting</h3>
                    <p>
                        Split shifts by time, date, weekday, or holiday. Create container templates
                        for recurring patterns. Handle prep time, post-processing, travel time, and
                        break scheduling &mdash; all in a <strong>hierarchical tree structure</strong>.
                    </p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon bg-orange"><i class="fas fa-chart-gantt"></i></div>
                    <h3>Absence Management</h3>
                    <p>
                        Visual Gantt diagrams show vacation, sick leave, and custom absence types at a glance.
                        <strong>Export to PDF</strong> with one click. Multi-language absence type names
                        adapt to each user's locale.
                    </p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon bg-red"><i class="fas fa-shield-halved"></i></div>
                    <h3>4-Stage Approval Workflow</h3>
                    <p>
                        From <em>Draft</em> to <em>Confirmed</em> to <em>Approved</em> to <em>Closed</em>.
                        Each stage locks further editing. Combined with <strong>group-based restrictions</strong>,
                        you control exactly who can change what.
                    </p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon bg-teal"><i class="fas fa-map-marked-alt"></i></div>
                    <h3>Route Optimization</h3>
                    <p>
                        Plan deployment routes with integrated <strong>OpenRouteService</strong>.
                        Ant colony optimization finds the shortest path. Supports car, bicycle,
                        walking, and mixed transport modes with automatic distance matrix calculation.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- AI Section -->
<section id="ai" class="ai-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <span class="section-badge">AI-Powered</span>
                <h2>Your personal<br /><span class="gradient-text">scheduling assistant</span></h2>
                <p class="lead">
                    Klacks comes with a built-in AI chat assistant that understands your workforce data.
                    Ask it to create users, assign shifts, analyze patterns, or generate reports &mdash;
                    all through natural language.
                </p>
                <ul class="ai-features-list">
                    <li>
                        <i class="fas fa-comments"></i>
                        <div>
                            <strong>Natural Language Control</strong>
                            <span>"Create a night shift from 22:00 to 06:00 for the care unit"</span>
                        </div>
                    </li>
                    <li>
                        <i class="fas fa-plug"></i>
                        <div>
                            <strong>Multi-Provider Support</strong>
                            <span>Connect OpenAI, Anthropic, or other LLM providers</span>
                        </div>
                    </li>
                    <li>
                        <i class="fas fa-bolt"></i>
                        <div>
                            <strong>UI Passthrough Execution</strong>
                            <span>AI actions execute directly in the interface &mdash; create users, manage branches, set permissions</span>
                        </div>
                    </li>
                    <li>
                        <i class="fas fa-brain"></i>
                        <div>
                            <strong>Skill System</strong>
                            <span>Extensible skill-based architecture. Add domain-specific capabilities without changing core code</span>
                        </div>
                    </li>
                    <li>
                        <i class="fas fa-server"></i>
                        <div>
                            <strong>MCP Server Integration</strong>
                            <span>Model Context Protocol server for external AI agent connectivity</span>
                        </div>
                    </li>
                </ul>
            </div>
            <div class="col-lg-6">
                <div class="ai-chat-demo">
