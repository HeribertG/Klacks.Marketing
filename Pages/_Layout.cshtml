<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Klacks - Open-source AI-powered workforce management. Intelligent scheduling, auto-fill planning, real-time collaboration. Free forever." />
    <meta name="keywords" content="workforce management, shift planning, employee scheduling, AI assistant, open source, auto-fill, schedule optimization" />
    <meta property="og:title" content="Klacks - AI-Powered Workforce Management" />
    <meta property="og:description" content="The open-source workforce management system that plans smarter than you. AI-driven scheduling, auto-fill, real-time updates." />
    <meta property="og:type" content="website" />
    <title>Klacks | AI-Powered Workforce Management</title>
    <base href="/" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="css/site.css" rel="stylesheet" />
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body class="font-['Inter'] bg-background text-on-background selection:bg-secondary-fixed selection:text-on-secondary-fixed">
    @RenderBody()

    <div id="blazor-error-ui">
        <environment include="Staging,Production">
            An error has occurred. This application may no longer respond until reloaded.
        </environment>
        <environment include="Development">
            An unhandled error has occurred. See browser console for details.
        </environment>
        <a href="" class="reload">Reload</a>
        <a class="dismiss">X</a>
    </div>

    <script src="~/_framework/blazor.server.js"></script>
</body>
</html>
